{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A monitoring target for the SRE dashboard.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "status": { "type": "string", "enum": ["healthy", "critical", "unknown"] },
        "lastScanAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "url", "status", "ownerId"]
    },
    "Scan": {
      "title": "Scan",
      "description": "A specific analysis performed by the AI agent.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "status": { "type": "string" },
        "confidenceScore": { "type": "number" },
        "issuesFound": { "type": "array", "items": { "type": "string" } },
        "recommendedFix": { "type": "string" },
        "suggestedPatch": { "type": "string" },
        "screenshotUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "status", "confidenceScore", "createdAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "The collection of monitored projects."
    },
    "/projects/{projectId}/scans/{scanId}": {
      "schema": "Scan",
      "description": "Historical scans for a specific project."
    }
  }
}
